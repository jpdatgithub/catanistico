@namespace MeuCatan.MudblazorWasmClient.Components.Catan
@using System.Globalization
@inject IJSRuntime JS

@if (State is null)
{
    <MudAlert Severity="Severity.Warning">Estado do tabuleiro indisponível.</MudAlert>
}
else
{
    var model = CatanBoardLayoutBuilder.Build(State);
    var transform = $"translate({F(_tx)},{F(_ty)}) scale({F(_scale)})";
    var cursor = _isDragging ? "grabbing" : "grab";

    <div @ref="_containerRef" style="width:100%; height:@(DisplayHeight)px; overflow:hidden; user-select:none;"
         @onmousemove="OnMouseMove" @onmouseup="OnMouseUp" @onmouseleave="OnMouseUp">
        <svg width="100%" height="100%" class="catan-board-svg" role="img" aria-label="Tabuleiro do Catan"
             style="display:block;" @onwheel="OnWheel" @onwheel:preventDefault @onmousedown="OnMouseDown">
            <g transform="@transform">
                @foreach (var tile in model.Tiles)
                {
                    <polygon points="@tile.Points" fill="@tile.Fill" stroke="#2f2f2f" stroke-width="2" />
                }
                @foreach (var vertex in model.Vertices)
                {
                    <circle cx="@F(vertex.X)" cy="@F(vertex.Y)" r="6" fill="#2f2f2f" />
                }

            </g>
        </svg>
    </div>
}

@code {
    private double CanvasWidth;
    private double CanvasHeight;
    private const double ZoomStep = 0.15;
    private const double ZoomMin = 0.3;
    private const double ZoomMax = 4.0;

    [Parameter] public CatanGameStateResponse? State { get; set; }
    [Parameter] public double DisplayWidth { get; set; } = 900;
    [Parameter] public double DisplayHeight { get; set; } = 700;

    // Transform state: translate(_tx, _ty) scale(_scale)
    private double _tx;
    private double _ty;
    private double _scale = 1.0;

    // Pan drag state
    private bool _isDragging;
    private double _dragStartX;
    private double _dragStartY;
    private double _txStart;
    private double _tyStart;

    // Measured container size (set after first render via JS interop)
    private ElementReference _containerRef;
    private double _containerW;
    private double _containerH;

    // Actual display dimensions — measured value takes priority over parameter
    private double W => _containerW > 0 ? _containerW : DisplayWidth;
    private double H => _containerH > 0 ? _containerH : DisplayHeight;

    protected override void OnInitialized()
    {
        // Initial estimate using parameter values; corrected in OnAfterRenderAsync
        CanvasWidth = State?.width ?? 1000;
        CanvasHeight = State?.height ?? 1000;
        _scale = Math.Min(DisplayWidth / CanvasWidth, DisplayHeight / CanvasHeight);
        _tx = (DisplayWidth - CanvasWidth * _scale) / 2.0;
        _ty = (DisplayHeight - CanvasHeight * _scale) / 2.0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var bounds = await JS.InvokeAsync<ElementBounds>("getElementBounds", _containerRef);
        if (bounds.Width <= 0) return;

        _containerW = bounds.Width;
        _containerH = bounds.Height;
        _scale = Math.Min(_containerW / CanvasWidth, _containerH / CanvasHeight);
        _tx = (_containerW - CanvasWidth * _scale) / 2.0;
        _ty = (_containerH - CanvasHeight * _scale) / 2.0;
        ClampPan();
        StateHasChanged();
    }

    private void OnWheel(WheelEventArgs e)
    {
        var factor = e.DeltaY < 0 ? (1.0 + ZoomStep) : (1.0 - ZoomStep);
        var newScale = Math.Clamp(_scale * factor, ZoomMin, ZoomMax);
        var ratio = newScale / _scale;

        // Keep the canvas point under the cursor fixed:
        // canvasPoint = (OffsetX - _tx) / _scale → invariant after zoom
        _tx = e.OffsetX - (e.OffsetX - _tx) * ratio;
        _ty = e.OffsetY - (e.OffsetY - _ty) * ratio;
        _scale = newScale;
        ClampPan();
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        if (e.Button != 0) return;
        _isDragging = true;
        _dragStartX = e.ClientX;
        _dragStartY = e.ClientY;
        _txStart = _tx;
        _tyStart = _ty;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging) return;
        // Delta in CSS px maps 1:1 to SVG user units (no viewBox)
        _tx = _txStart + (e.ClientX - _dragStartX);
        _ty = _tyStart + (e.ClientY - _dragStartY);
        ClampPan();
    }

    private void OnMouseUp(MouseEventArgs e) => _isDragging = false;

    // Ensures at least `margin` px of canvas remains visible on each side
    private void ClampPan()
    {
        var scaledW = CanvasWidth * _scale;
        var scaledH = CanvasHeight * _scale;
        const double margin = 300;
        _tx = Math.Clamp(_tx, -(scaledW - margin), W - margin);
        _ty = Math.Clamp(_ty, -(scaledH - margin), H - margin);
    }

    private static string F(double v) => v.ToString("F4", CultureInfo.InvariantCulture);

    private record ElementBounds(double Width, double Height);
}
